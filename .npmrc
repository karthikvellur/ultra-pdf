# Pin the public npm registry for this project.
#
# Without this, npm falls back to the user's global ~/.npmrc, which on an
# Intuit-configured machine points at the internal Artifactory mirror
# (registry.npmjs.intuit.com). That mirror is unreachable from outside the
# corporate network/VPN — including Cloudflare Pages' build servers — which
# silently hung `npm ci` for ~8 minutes before crashing with npm's own
# "Exit handler never called!" bug. Pinning the public registry here makes
# installs reproducible on any third-party CI/host, not just this machine.
registry=https://registry.npmjs.org/
