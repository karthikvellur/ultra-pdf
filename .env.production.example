# Production build config for the frontend.
#
# Set this in Cloudflare Pages → Settings → Environment variables (Production),
# OR copy this file to `.env.production` locally before `npm run build`.
#
# The value is your deployed backend's base URL (no trailing slash).
# Render web service URLs look like:
#   https://<service-name>.onrender.com
VITE_API_BASE=https://ultra-pdf-backend.onrender.com
